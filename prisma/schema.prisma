generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BusinessType {
  SOLE_TRADER
  LIMITED_COMPANY
  NOT_SURE
}

enum AnswerChoice {
  YES
  NO
  NOT_SURE
}

enum TaskStatus {
  DUE_SOON
  COMING_UP
  COMPLETED
  NEEDS_INFORMATION
  OVERDUE
  NOT_APPLICABLE
}

enum TaskUrgency {
  LOW
  NORMAL
  HIGH
}

enum ReminderFrequency {
  WEEKLY
  MONTHLY
  CUSTOM
}

enum ReviewStatus {
  CURRENT
  NEEDS_REVIEW
  RETIRED
}

enum SubscriptionTier {
  FREE
  STARTER
  PRO
}

enum AuthEmailPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum UserRole {
  USER
  ADMIN
}

enum VatAccountingPeriod {
  MONTHLY
  QUARTERLY
  ANNUALLY
  NOT_SURE
}

enum TaskHistoryAction {
  CREATED
  RECALCULATED
  COMPLETED
  MARKED_NOT_APPLICABLE
  RESTORED
  NOTE_UPDATED
}

enum ReminderInterval {
  THIRTY_DAYS
  FOURTEEN_DAYS
  SEVEN_DAYS
  ONE_DAY
  OVERDUE
}

model User {
  id                    String    @id @default(cuid())
  name                  String?
  email                 String    @unique
  emailVerified         DateTime?
  image                 String?
  passwordHash          String?
  resetTokenHash        String?
  resetTokenExpiresAt   DateTime?
  consentEmailReminders Boolean   @default(false)
  consentProductUpdates Boolean   @default(false)
  role                  UserRole  @default(USER)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  accounts                 Account[]
  sessions                 Session[]
  businesses               Business[]
  subscriptions            Subscription[]
  auditLogs                AuditLog[]
  conversations            AIConversation[]
  taskHistory              TaskHistory[]
  complianceContentChanges ComplianceRuleContentVersion[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AuthEmailAttempt {
  id        String           @id @default(cuid())
  emailHash String
  purpose   AuthEmailPurpose
  createdAt DateTime         @default(now())

  @@index([emailHash, purpose, createdAt])
}

model Business {
  id        String       @id @default(cuid())
  userId    String
  name      String
  type      BusinessType @default(NOT_SURE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile              BusinessProfile?
  tasks                Task[]
  deadlines            Deadline[]
  reminders            Reminder[]
  transactionSummaries TransactionSummary[]
  taxEstimates         TaxEstimate[]
  documents            Document[]
  subscriptions        Subscription[]
}

model BusinessProfile {
  id                       String              @id @default(cuid())
  businessId               String              @unique
  businessType             BusinessType        @default(NOT_SURE)
  legalBusinessName        String?
  tradingName              String?
  companyNumber            String?
  worksAlone               AnswerChoice        @default(NOT_SURE)
  startedTradingOn         DateTime?
  companyRegisteredOn      DateTime?
  accountingReferenceDate  DateTime?
  firstAccountingPeriodEnd DateTime?
  paysSelfThroughCompany   AnswerChoice        @default(NOT_SURE)
  registeredForVat         AnswerChoice        @default(NOT_SURE)
  vatRegisteredOn          DateTime?
  vatAccountingPeriod      VatAccountingPeriod @default(NOT_SURE)
  vatPeriodEndsOn          DateTime?
  employsPeople            AnswerChoice        @default(NOT_SURE)
  firstPayday              DateTime?
  usesAccountant           AnswerChoice        @default(NOT_SURE)
  businessYearEndMonth     Int?
  wantsEmailReminders      Boolean             @default(false)
  salesSoFarPence          Int                 @default(0)
  costsSoFarPence          Int                 @default(0)
  onboardingCompletedAt    DateTime?
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Task {
  id                     String      @id @default(cuid())
  businessId             String
  key                    String?
  title                  String
  plainEnglishSummary    String
  dueDate                DateTime?
  urgency                TaskUrgency @default(NORMAL)
  status                 TaskStatus  @default(COMING_UP)
  nextAction             String      @default("")
  whatThisMeans          String      @default("")
  whyYouMayNeedIt        String      @default("")
  calculationInput       Json?
  calculationExplanation String      @default("")
  ruleVersion            String      @default("stage-1")
  sourceTitle            String?
  sourceCheckedAt        DateTime?
  missingInformation     String[]
  whatYouNeed            String[]
  checklist              String[]
  officialSourceUrl      String?
  adviceBoundary         String
  completedAt            DateTime?
  completedNote          String?
  notApplicableAt        DateTime?
  notApplicableReason    String?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  business           Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  history            TaskHistory[]
  reminderDeliveries ReminderDelivery[]

  @@unique([businessId, key])
  @@index([businessId, status, dueDate])
}

model TaskHistory {
  id        String            @id @default(cuid())
  taskId    String
  userId    String?
  action    TaskHistoryAction
  note      String?
  metadata  Json?
  createdAt DateTime          @default(now())

  task Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt])
}

model ReminderDelivery {
  id         String           @id @default(cuid())
  taskId     String
  interval   ReminderInterval
  sentTo     String
  sentAt     DateTime         @default(now())
  providerId String?

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, interval])
  @@index([sentAt])
}

model Deadline {
  id                   String     @id @default(cuid())
  businessId           String
  plainEnglishName     String
  officialName         String?
  dueDate              DateTime
  explanation          String
  preparationChecklist String[]
  status               TaskStatus @default(COMING_UP)
  reminderSettings     Json?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Reminder {
  id         String            @id @default(cuid())
  businessId String
  title      String
  frequency  ReminderFrequency
  customRule String?
  paused     Boolean           @default(false)
  sendEmail  Boolean           @default(false)
  nextRunAt  DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model TransactionSummary {
  id                  String   @id @default(cuid())
  businessId          String
  periodStart         DateTime
  periodEnd           DateTime
  salesPence          Int      @default(0)
  businessCostsPence  Int      @default(0)
  missingRecordsCount Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model TaxEstimate {
  id                 String   @id @default(cuid())
  businessId         String
  salesPence         Int
  businessCostsPence Int
  amountSavedPence   Int      @default(0)
  estimatePence      Int
  ruleVersion        String
  disclaimer         String
  createdAt          DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Document {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  kind        String
  storageKey  String?
  savedByUser Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business     Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  explanations DocumentExplanation[]
}

model DocumentExplanation {
  id             String    @id @default(cuid())
  documentId     String
  summary        String
  actionNeeded   String
  dueDate        DateTime?
  adviceBoundary String
  sourceLinks    String[]
  createdAt      DateTime  @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model AIConversation {
  id        String   @id @default(cuid())
  userId    String
  title     String
  messages  Json
  sources   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GlossaryTerm {
  id                String   @id @default(cuid())
  officialTerm      String   @unique
  simpleExplanation String
  whyItMatters      String
  whereYouMaySeeIt  String
  example           String
  officialSourceUrl String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ComplianceRule {
  id            String       @id @default(cuid())
  key           String
  plainName     String
  description   String
  effectiveFrom DateTime
  effectiveTo   DateTime?
  sourceUrl     String
  checkedAt     DateTime
  reviewStatus  ReviewStatus @default(CURRENT)
  metadata      Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  contentVersions ComplianceRuleContentVersion[]

  @@unique([key, effectiveFrom])
}

model ComplianceRuleContentVersion {
  id               String   @id @default(cuid())
  complianceRuleId String
  plainName        String
  description      String
  sourceUrl        String
  checkedAt        DateTime
  active           Boolean  @default(true)
  changedByUserId  String?
  changeNote       String?
  createdAt        DateTime @default(now())

  complianceRule ComplianceRule @relation(fields: [complianceRuleId], references: [id], onDelete: Cascade)
  changedBy      User?          @relation(fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([complianceRuleId, createdAt])
}

model OfficialSource {
  id           String       @id @default(cuid())
  title        String
  url          String       @unique
  publisher    String
  checkedAt    DateTime
  reviewStatus ReviewStatus @default(CURRENT)
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Subscription {
  id                   String           @id @default(cuid())
  userId               String
  businessId           String?
  tier                 SubscriptionTier @default(FREE)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  status               String           @default("configuration-only")
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}
